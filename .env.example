NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# mock or spotify
MUSIC_PROVIDER=mock

# Required only for Spotify host playback control.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
SPOTIFY_REFRESH_TOKEN=

# Optional, used for QR/link text in local and deployed environments.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional, comma-separated display names that receive unlimited credits when joining.
SUPER_USER_NAMES=

# Optional, timezone used to reset daily credits.
CREDIT_TIME_ZONE=America/Chicago
